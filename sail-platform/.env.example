# Copy to .env and fill in a key:  cp .env.example .env
#
# The harness + chat UI read these from the environment. Only the provider
# you actually use needs a key. OpenRouter is the default (config/models.openrouter.yaml).
# You can also add a key later from the chat UI's model picker (the [+] button).

# OpenRouter — default provider (Gemma 4 31B via config/models.openrouter.yaml)
OPENROUTER_API_KEY=sk-or-...

# Optional — only if you switch to these providers
# ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=AIza...
